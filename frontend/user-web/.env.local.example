# 复制为 .env.local 后由 Next.js 读取（不要提交 .env.local）
# 须与后端 PORT 一致，供 next.config.js 中 rewrites 代理到 Flask

NEXT_PUBLIC_API_URL=http://127.0.0.1:5001

# 前端管理员权限阈值：membership_level >= 该值才显示“后台管理”并可进入 /admin
NEXT_PUBLIC_ADMIN_MEMBERSHIP_LEVEL=9
NEXT_PUBLIC_AI_SERVICE_URL=http://127.0.0.1:5001
NEXT_PUBLIC_ADMIN_URL=http://127.0.0.1:3001
