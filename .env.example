# =============================================================================
# 本地开发（Flask + Next.js user-web）——换机器后优先改这里
# =============================================================================
# 后端监听端口（与 frontend/user-web/.env.local 中 NEXT_PUBLIC_API_URL 一致）
PORT=5001

# 根路径 / 默认 302 到用户前端；设为 1 时根路径仍显示聚合入口（否则入口在 /portal）
# DISABLE_INDEX_REDIRECT=1
FRONTEND_URL=http://127.0.0.1:3000
ADMIN_URL=http://127.0.0.1:3001

# data_services_manager：设为 1 可跳过 Docker 数据服务（本地只用 SQLite 时减少日志）
# SKIP_DATA_SERVICES=1

# 景点图片根目录（/api/media 从此目录下读取 scenic_images/...）
SCENIC_IMAGES_ROOT=D:\travel-assistant\scenic_images

# 导入脚本 scripts/import_destinations_from_json.py 读取的 JSON
DESTINATIONS_JSON_PATH=D:\travel-assistant\destinations.json

# 前端构建时可选用（开发时更推荐用 frontend/user-web/.env.local）
NEXT_PUBLIC_API_URL=http://127.0.0.1:5001
NEXT_PUBLIC_AI_SERVICE_URL=http://127.0.0.1:5001

# =============================================================================
# 天气服务配置（心知天气 - https://www.seniverse.com/）
# 免费额度：每日1000次调用，完全够个人测试使用
# =============================================================================
SENIVERSE_API_KEY=your-seniverse-api-key

# =============================================================================
# 以下为历史/其它模块占位，可按需使用
# =============================================================================

# 管理员权限阈值：membership_level >= 该值才可访问 /api/admin/* 与前端 /admin 页面
ADMIN_MEMBERSHIP_LEVEL=9

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_NAME=travel_assistant
DB_USER=root
DB_PASSWORD=change-me-db-password
SQLALCHEMY_DATABASE_URI=sqlite:///travel.db
SECRET_KEY=travel-assistant-dev-secret-change-me

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379/0
REDIS_SOCKET_CONNECT_TIMEOUT=5
REDIS_SOCKET_TIMEOUT=5

# JWT配置
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=24h

# AI服务配置
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4
OPENAI_MAX_TOKENS=2000
OPENAI_BASE_URL=https://api.openai.com

# 智谱 GLM-4
ZHIPU_API_KEY=your-zhipu-api-key
ZHIPU_MODEL=glm-4.5-air
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# AWS Bedrock (Claude/Titan/DeepSeek/Qwen/MiniMax)
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1
AWS_BEDROCK_MODEL=amazon.titan-text-express-v1

# 向量数据库配置
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_DB=travel_assistant

# Elasticsearch配置
ELASTICSEARCH_HOST=localhost
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_INDEX=travel_products

# 消息队列配置
ROCKETMQ_NAME_SERVER=localhost:9876
ROCKETMQ_TOPIC_PREFIX=travel

# 文件存储配置
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=travel-assistant

# 监控配置
PROMETHEUS_URL=http://localhost:9090
GRAFANA_URL=http://localhost:3000
GRAFANA_USERNAME=admin
GRAFANA_PASSWORD=admin

# 第三方服务配置
ALIPAY_APP_ID=your-alipay-app-id
ALIPAY_PRIVATE_KEY=your-alipay-private-key
ALIPAY_PUBLIC_KEY=your-alipay-public-key

WECHAT_APP_ID=your-wechat-app-id
WECHAT_APP_SECRET=your-wechat-app-secret
WECHAT_MCH_ID=your-wechat-mch-id
WECHAT_KEY=your-wechat-key

# 短信服务配置
SMS_ACCESS_KEY=your-sms-access-key
SMS_SECRET_KEY=your-sms-secret-key
SMS_SIGN_NAME=您的签名

# 邮件服务配置
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-email-password

# 文件上传配置
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760  # 10MB
ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,pdf,doc,docx

# 缓存配置
CACHE_TTL=3600  # 1小时
CACHE_PREFIX=travel_

# 数据服务容器凭据（用于 launcher/manager 默认配置）
MYSQL_ROOT_PASSWORD=change-me-mysql-root
MYSQL_DATABASE=travel_assistant
MYSQL_USER=travel_user
MYSQL_PASSWORD=change-me-mysql-user
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=change-me-mongo
NEO4J_AUTH=neo4j/change-me
RABBITMQ_DEFAULT_USER=admin
RABBITMQ_DEFAULT_PASS=change-me-rabbitmq
DOCKER_INFLUXDB_INIT_PASSWORD=change-me-influxdb

# 日志配置
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# 安全配置
BCRYPT_ROUNDS=12
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=1h

# API配置
API_VERSION=v1
API_TIMEOUT=30
API_RATE_LIMIT=1000

# 前端配置（若未使用 frontend/user-web/.env.local，可依赖此处）
NEXT_PUBLIC_ENVIRONMENT=development