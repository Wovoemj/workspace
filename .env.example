# Travel Assistant 环境变量配置
# 复制为 .env 后使用

# ============ 必填（生产环境）============
# JWT 签名密钥，生产环境必须设置
# SECRET_KEY=your-secret-key-here

# ============ 可选（开发环境默认值）============
# Flask 运行环境：development / production
# FLASK_ENV=development

# 服务器端口
# PORT=5001

# 数据库连接（SQLite 默认）
# SQLALCHEMY_DATABASE_URI=sqlite:///instance/travel.db

# ============ Redis 缓存（可选）============
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_DB=0
# REDIS_PASSWORD=
# REDIS_SOCKET_CONNECT_TIMEOUT=5
# REDIS_SOCKET_TIMEOUT=5
# CACHE_TTL=300

# ============ 管理员配置 ============
# 管理员权限阈值：membership_level >= 该值可进入后台
# ADMIN_MEMBERSHIP_LEVEL=9

# ============ 天气 API（心知天气）============
# https://www.seniverse.com/
# SENIVERSE_API_KEY=your-seniverse-api-key

# ============ AI 大模型（至少配置一个）============
# Moonshot AI (Kimi)
# MOONSHOT_API_KEY=your-moonshot-api-key
# MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
# MOONSHOT_MODEL=moonshot-v1-8k

# 智谱 AI (GLM)
# ZHIPU_API_KEY=your-zhipu-api-key
# ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# ZHIPU_MODEL=glm-4-flash
# ZHIPU_MODEL_BACKUP=glm-4.5-air

# OpenAI（可选）
# OPENAI_API_KEY=your-openai-api-key
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-3.5-turbo

# ============ AWS Bedrock（预留，暂未实现）============
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1

# ============ 支付接口（预留，暂未实现）============
# 支付宝
# ALIPAY_APP_ID=
# ALIPAY_PRIVATE_KEY=
# ALIPAY_PUBLIC_KEY=
# ALIPAY_GATEWAY=https://openapi.alipay.com/gateway.do

# 微信支付
# WECHAT_MCH_ID=
# WECHAT_API_KEY=
# WECHAT_NOTIFY_URL=

# ============ 以下为未使用的配置（已删除）============
# Milvus / Elasticsearch / RocketMQ / MinIO / Neo4j / RabbitMQ / InfluxDB
# 如需使用，请自行添加并实现对应功能